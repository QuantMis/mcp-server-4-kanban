# Copy to .env and fill in. Do NOT commit the real .env.
#
# API key for the dedicated Planka agent user (preferred over username/password).
# Mint one with:
#   curl -X POST https://planka.codedancoffee.com/api/access-tokens \
#     -H "Content-Type: application/json" \
#     -d '{"emailOrUsername":"claude-agent@codedancoffee.com","password":"<agent-password>"}'
PLANKA_API_KEY=replace-with-agent-token
